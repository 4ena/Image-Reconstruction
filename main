cv2.imwrite("noisy_image.jpg", cv2.cvtColor(noisy_img, cv2.COLOR_RGB2BGR))
cv2.imwrite("inpainted_image.jpg", cv2.cvtColor(inpainted_img, cv2.COLOR_RGB2BGR))
cv2.imwrite("bilateral_image.jpg", cv2.cvtColor(bilateral_img, cv2.COLOR_RGB2BGR))
cv2.imwrite("nlm_denoised_image.jpg", cv2.cvtColor(nlm_denoised_img, cv2.COLOR_RGB2BGR))
cv2.imwrite("wavelet_denoised_image.jpg", cv2.cvtColor(wavelet_denoised_img, cv2.COLOR_RGB2BGR))
