cv2.imwrite("final_reconstructed_image.jpg", cv2.cvtColor(final_img, cv2.COLOR_RGB2BGR))
cv2.imwrite("nlm_direct_image.jpg", cv2.cvtColor(nlm_direct_img, cv2.COLOR_RGB2BGR))
