# -----------------------------
# Save Detailed Results Table
# -----------------------------

results_rows = []

for experiment in all_experiments:
    image_name = experiment["name"].replace(".jpg", "").title()

    for method_name, metrics in experiment["results"].items():
        results_rows.append({
            "Image": image_name,
            "Sampling Rate": experiment["sampling_rate"],
            "Method": method_name,
            "MSE": metrics["MSE"],
            "PSNR": metrics["PSNR"],
            "SSIM": metrics["SSIM"],
            "Data Fidelity": metrics["Data Fidelity"]
        })

results_df = pd.DataFrame(results_rows)

results_df.to_csv(
    "five_image_results.csv",
    index=False
)

print("\nFive-Image Results")
print(results_df.round(4))
# -----------------------------
# Average Results Across Images
# -----------------------------

summary_df = results_df.groupby(
    ["Sampling Rate", "Method"]
).agg(
    MSE_Mean=("MSE", "mean"),
    MSE_Std=("MSE", "std"),
    PSNR_Mean=("PSNR", "mean"),
    PSNR_Std=("PSNR", "std"),
    SSIM_Mean=("SSIM", "mean"),
    SSIM_Std=("SSIM", "std"),
    Fidelity_Mean=("Data Fidelity", "mean"),
    Fidelity_Std=("Data Fidelity", "std")
).reset_index()

summary_df.to_csv(
    "five_image_summary.csv",
    index=False
)

print("\nAverage Results Across Five Images")
print(summary_df.round(4))
# -----------------------------
# Overall Table
# -----------------------------

method_order = [
    "Noisy Sampled",
    "Inpainted",
    "Bilateral",
    "Wavelet",
    "Light NLM",
    "Hybrid"
]

overall_df = results_df.groupby("Method").agg(
    MSE_Mean=("MSE", "mean"),
    MSE_Std=("MSE", "std"),
    PSNR_Mean=("PSNR", "mean"),
    PSNR_Std=("PSNR", "std"),
    SSIM_Mean=("SSIM", "mean"),
    SSIM_Std=("SSIM", "std")
).reindex(method_order).reset_index()

overall_df.to_csv(
    "overall_method_summary.csv",
    index=False
)

# Format values as mean ± standard deviation
poster_table_df = pd.DataFrame({
    "Method": overall_df["Method"].replace({
        "Hybrid": "Proposed Hybrid"
    }),

    "MSE ↓": [
        f"{mean:.2f} ± {std:.2f}"
        for mean, std in zip(
            overall_df["MSE_Mean"],
            overall_df["MSE_Std"]
        )
    ],

    "PSNR (dB) ↑": [
        f"{mean:.2f} ± {std:.2f}"
        for mean, std in zip(
            overall_df["PSNR_Mean"],
            overall_df["PSNR_Std"]
        )
    ],

    "SSIM ↑": [
        f"{mean:.3f} ± {std:.3f}"
        for mean, std in zip(
            overall_df["SSIM_Mean"],
            overall_df["SSIM_Std"]
        )
    ]
})

print("\nOverall Performance Across All Image-Sampling Conditions")
print(poster_table_df)

