# -----------------------------
# Win Counts Across Conditions
# -----------------------------

competitive_methods = [
    "Light NLM",
    "Wavelet",
    "Hybrid"
]

competitive_df = results_df[
    results_df["Method"].isin(competitive_methods)
].copy()

condition_columns = [
    "Image",
    "Sampling Rate"
]

mse_winners = competitive_df.loc[
    competitive_df.groupby(condition_columns)["MSE"].idxmin(),
    "Method"
].value_counts()

psnr_winners = competitive_df.loc[
    competitive_df.groupby(condition_columns)["PSNR"].idxmax(),
    "Method"
].value_counts()

ssim_winners = competitive_df.loc[
    competitive_df.groupby(condition_columns)["SSIM"].idxmax(),
    "Method"
].value_counts()

win_counts_df = pd.DataFrame({
    "Method": competitive_methods,
    "Lowest MSE Wins": [
        mse_winners.get(method, 0)
        for method in competitive_methods
    ],
    "Highest PSNR Wins": [
        psnr_winners.get(method, 0)
        for method in competitive_methods
    ],
    "Highest SSIM Wins": [
        ssim_winners.get(method, 0)
        for method in competitive_methods
    ]
})

win_counts_df["Method"] = win_counts_df["Method"].replace({
    "Hybrid": "Proposed Hybrid"
})

win_counts_df.to_csv(
    "method_win_counts.csv",
    index=False
)

print("\nMethod Win Counts Across 20 Conditions")
print(win_counts_df)
